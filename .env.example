# Configuration pour l'envoi d'emails (Nodemailer)
# Renommez ce fichier en `.env` et remplissez vos informations.

# L'hôte SMTP de votre fournisseur d'accès (ex: smtp.gmail.com pour Gmail, smtp.office365.com pour Outlook)
SMTP_HOST=smtp.gmail.com

# Le port SMTP (souvent 587, 465, ou 25)
SMTP_PORT=587

# true si port 465, false pour 587 et autres
SMTP_SECURE=false

# Votre adresse email d'envoi
SMTP_USER=votre.email@gmail.com

# Votre mot de passe email (ou un mot de passe d'application si vous avez l'A2F activée)
SMTP_PASS=votre_mot_de_passe

# L'adresse email qui doit RECEVOIR l'alerte
EMAIL_TO=votre.email.destinataire@gmail.com
